public class VirtualThreadConfig {
    public static void main(String[] args) throws InterruptedException {
        System.out.println("Starting configured virtual threads...");

        // 1. Create a virtual thread with a custom name
        Thread namedThread = Thread.ofVirtual()
                                   .name("worker-", 1) // Name will be "worker-1"
                                   .start(() -> {
                                       System.out.println("Running: " + Thread.currentThread().getName());
                                   });
        
        namedThread.join();

        // 2. Create a Daemon virtual thread (doesn't prevent JVM exit)
        Thread daemonThread = Thread.ofVirtual()
                                    .daemon(true)
                                    .start(() -> {
                                        while (true) {
                                            System.out.println("Daemon working...");
                                            try { Thread.sleep(1000); } catch (InterruptedException e) { break; }
                                        }
                                    });

        System.out.println("Main thread sleeping for 3 seconds...");
        Thread.sleep(3000);
        System.out.println("Main thread exiting. Daemon will stop automatically.");
    }
}